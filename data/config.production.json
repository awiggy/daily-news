{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "deepseek-chat",
    "base_url": "https://api.deepseek.com/v1",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 1,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": ["zh", "en"]
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 50
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": false,
        "category": "ai-tools"
      },
      {
        "name": "Google News - AI行业",
        "url": "https://news.google.com/rss/search?q=artificial+intelligence+OR+LLM+OR+GPT&hl=zh-CN&gl=CN&ceid=CN:zh-Hans",
        "enabled": false,
        "category": "ai-industry"
      },
      {
        "name": "Google News - 科技（半导体+新能源）",
        "url": "https://news.google.com/rss/search?q=半导体+OR+芯片+OR+新能源+OR+光伏+OR+锂电+OR+电动车&hl=zh-CN&gl=CN&ceid=CN:zh-Hans",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "Google News - 金融市场",
        "url": "https://news.google.com/rss/search?q=IPO+OR+上市+OR+美联储+OR+利率+OR+A股&hl=zh-CN&gl=CN&ceid=CN:zh-Hans",
        "enabled": true,
        "category": "finance"
      },
      {
        "name": "Google News - 全球宏观",
        "url": "https://news.google.com/rss/search?q=world+economy+OR+inflation+OR+central+bank+OR+trade+war&hl=en&gl=US&ceid=US:en",
        "enabled": true,
        "category": "macro"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "LocalLLaMA", "enabled": true, "sort": "hot",
          "time_filter": "day", "fetch_limit": 15, "min_score": 20
        },
        {
          "subreddit": "MachineLearning", "enabled": true, "sort": "hot",
          "time_filter": "day", "fetch_limit": 10, "min_score": 30
        },
        {
          "subreddit": "singularity", "enabled": true, "sort": "hot",
          "time_filter": "day", "fetch_limit": 10, "min_score": 50
        },
        {
          "subreddit": "investing", "enabled": true, "sort": "hot",
          "time_filter": "day", "fetch_limit": 10, "min_score": 30
        }
      ],
      "fetch_comments": 5
    }
  },
  "filtering": {
    "ai_score_threshold": 7.0,
    "time_window_hours": 24
  }
}
